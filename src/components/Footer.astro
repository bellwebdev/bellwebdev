---
import styles from "./Footer.module.scss";
import { iconHtml } from "../utils/icon";
import {
  faLinkedinIn,
  faFacebook,
} from "@fortawesome/free-brands-svg-icons";

const year = new Date().getFullYear();

// TODO: swap in real profile URLs
const social = {
  linkedin: "#",
  facebook: "#",
};
---

<footer class="darkBlueBg whiteText">
  <div class={`container ${styles.footerInner}`}>
    <div class={styles.topRow}>
      <div class={styles.navCol}>
        <img
          src="/projectImages/BellWebDevPicWhite.png"
          width="40"
          height="40"
          alt="Bell WebDev logo"
        />
        <a class={styles.navLinkFirst} href="/about">About</a>
        <a class={styles.navLink} href="/services">Services</a>
        <a class={styles.navLink} href="/portfolio">Portfolio</a>
        <a class={styles.navLink} href="/blog">Blog</a>
      </div>
      <hr class={`turqoiseText ${styles.divider}`} />
    </div>
    <div class={styles.bottomRow}>
      <div class={styles.copyCol}>
        <p class={styles.copyText}>&copy; {year} Bell WebDev</p>
      </div>
      <div class={styles.socialCol}>
        <a
          href={social.linkedin}
          class={styles.socialIcon}
          aria-label="Bell WebDev on LinkedIn"
          set:html={iconHtml(faLinkedinIn)}
        />
        <a
          href={social.facebook}
          class={styles.socialIcon}
          aria-label="Bell WebDev on Facebook"
          set:html={iconHtml(faFacebook)}
        />
      </div>
    </div>
  </div>
</footer>
