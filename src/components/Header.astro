---
import styles from "./Header.module.scss";
---

<div>
  <nav class={styles.navbar}>
    <div class={`container ${styles.inner}`}>
      <a href="/" class={styles.brand}>
        <img
          src="/projectImages/BellWebDevHFullVector.svg"
          width="150"
          height="50"
          alt="Bell WebDev Logo"
        />
      </a>
      <button
        type="button"
        class={styles.navToggle}
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label="Toggle navigation menu"
        data-nav-toggle
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <div id="primary-nav" class={styles.navLinks} data-nav-links>
        <a class="darkBlueText" href="/about">About</a>
        <a class="darkBlueText" href="/services">Services</a>
        <a class="darkBlueText" href="/portfolio">Portfolio</a>
        <a class="darkBlueText" href="/blog">Blog</a>
      </div>
    </div>
  </nav>
</div>

<script>
  const toggle = document.querySelector("[data-nav-toggle]");
  const nav = document.querySelector("[data-nav-links]");

  toggle?.addEventListener("click", () => {
    const isOpen = nav.dataset.open === "true";
    nav.dataset.open = String(!isOpen);
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
