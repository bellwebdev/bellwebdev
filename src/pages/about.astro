---
import Layout from "../layouts/Layout.astro";
import TwoColumn from "../layouts/TwoColumn/TwoColumn.astro";
import HeroBanner from "../components/HeroBanner.astro";
import ContactForm from "../components/ContactForm.astro";
import styles from "./about.module.scss";
---

<Layout
  title="About Bell WebDev | Lehigh Valley Web Developer"
  description="Bell WebDev is a freelance web development practice backed by 5 years of professional Web Engineering experience, serving Lehigh Valley businesses."
>
  <main>
    <section class="darkBlueBg">
      <HeroBanner
        bgColor="darkBlueBg"
        btn={true}
        img="/projectImages/vibey-web-dev-image.jpg"
        imgAlt="Developer working at a laptop"
        heading="About Bell WebDev"
        subheading="Local Lehigh Valley web development, backed by 5 years of professional engineering experience."
      />
    </section>
    <section>
      <div class={`container ${styles.about} ${styles.introSection}`}>
        <div class={styles.introRow}>
          <div class={styles.introCol}>
            <p>
              Bell WebDev is a freelance web development practice built on one
              idea: local businesses deserve the same quality of engineering
              that big companies pay six figures for internally.
            </p>
            <p>
              I bring 5 years of professional Web Engineering experience —
              currently at a mid-size company (~4,500 employees) — to every
              project I take on. That day-to-day experience building and
              maintaining production software used by real customers is what
              shapes how I approach freelance work: code that's fast, reliable,
              and built to last, not just something that looks good in a demo.
            </p>
            <p>
              I take on a limited number of local projects alongside my
              full-time engineering work, so I'm selective about what I commit
              to — but that also means every client gets focused attention and
              realistic timelines, not a rushed job squeezed between a dozen
              others.
            </p>
          </div>
        </div>
      </div>
    </section>
    <section class="blueBg">
      <div class={`container ${styles.aboutInner}`}>
        <TwoColumn>
          <Fragment slot="left">
            <div class="whiteText">
              <h2>A Bit About How I Work</h2>
              <ul class={styles.workList}>
                <li>
                  Direct communication — you're talking to the person
                  actually writing your code, not a project manager relaying
                  messages.
                </li>
                <li>
                  No bloated subscriptions or page-builder lock-in — you own
                  your site outright.
                </li>
                <li>
                  Practical recommendations — I'll tell you honestly if you
                  need a $300 static site or something more complex. I'm not
                  here to upsell you.
                </li>
                <li>
                  Realistic turnaround — since this is alongside a full-time
                  role, timelines are typically 2–4 weeks rather than
                  same-day availability. I'll set clear expectations upfront.
                </li>
              </ul>
              <h2 class={styles.locationHeading}>Where I'm Located</h2>
              <p>
                I'm based in the Lehigh Valley in Pennsylvania, but if you're
                not local, I work with clients from all over.
              </p>
              <p class={styles.lastText}>
                If you are in the area and are interested in working
                together, feel free to fill out the contact form and request
                an in-person meeting.
              </p>
            </div>
          </Fragment>
          <Fragment slot="right">
            <img
              class="maxImageSize img-rounded"
              src="/projectImages/women-looking-at-laptop.jpeg"
              alt="Woman looking at a laptop"
            />
          </Fragment>
        </TwoColumn>
      </div>
    </section>
    <section class={`container ${styles.finalSection}`}>
      <ContactForm
        formHeading="Let's build something that works for your business."
        formSubhead="Tell me a bit about your project and I'll get back to you within one business day with a straightforward quote."
      />
    </section>
  </main>
</Layout>
