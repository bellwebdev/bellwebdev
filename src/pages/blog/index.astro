---
import Layout from "../../layouts/Layout.astro";
import HeroBanner from "../../components/HeroBanner.astro";
import ContactForm from "../../components/ContactForm.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
import styles from "./blog.module.scss";

const posts = await getCollection("blog");
const featured = posts.filter((p) => p.data.featured);
const howTo = posts.filter((p) => p.data.category === "how-to");
const agencyLife = posts.filter((p) => p.data.category === "agency-life");

const sections = [
  { id: "featured", label: "Featured", posts: featured },
  { id: "how-to", label: "How-To & Tutorials", posts: howTo },
  { id: "agency-life", label: "Agency Life", posts: agencyLife },
].filter((section) => section.posts.length > 0);
---

<Layout
  title="Blog | Bell WebDev"
  description="Tutorials, project highlights, and agency updates from Bell WebDev."
  image="/projectImages/blog-home.webp"
>
  <main>
    <section class="darkBlueBg">
      <HeroBanner
        bgColor="darkBlueBg"
        btn={true}
        img="/projectImages/blog-home.webp"
        imgAlt="Bell WebDev blog"
        heading="Insights & Inspiration from the Frontlines of Web Development"
        subheading="Explore expert tips, project highlights, and agency updates designed to help you build smarter, faster, and better digital experiences."
      />
    </section>
    <section>
      <div class={`container ${styles.blogHome}`}>
        <h2 class={styles.sectionHeading}>
          Behind-the-scenes looks at how our team solves real-world web
          challenges.
        </h2>
        <hr />
        {
          sections.length > 1 && (
            <div
              class={styles.sectionNav}
              role="tablist"
              aria-label="Blog categories"
            >
              {sections.map((section, index) => (
                <button
                  type="button"
                  role="tab"
                  id={`tab-${section.id}`}
                  aria-controls={`panel-${section.id}`}
                  aria-selected={index === 0 ? "true" : "false"}
                  tabindex={index === 0 ? "0" : "-1"}
                  class={styles.tabButton}
                  data-tab-button
                  data-target={section.id}
                >
                  {section.label}
                </button>
              ))}
            </div>
          )
        }
        {
          sections.map((section, index) => (
            <div
              id={`panel-${section.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${section.id}`}
              class={styles.tabContainer}
              data-tab-panel={section.id}
              hidden={sections.length > 1 && index !== 0}
            >
              <div class={styles.postsRow}>
                {section.posts.map((post) => (
                  <div class={styles.postCol}>
                    <BlogCard entry={post} />
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
    <section class="blueOpacityBg">
      <div class="container">
        <ContactForm
          formHeading="Build the Future of Your Business with Custom Web Solutions"
          formSubhead="Partner with Our Expert Team to Create Scalable, High-Performance Websites That Drive Results."
        />
      </div>
    </section>
  </main>
</Layout>

<script>
  const tabButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-tab-button]"),
  );

  function activateTab(button: HTMLButtonElement) {
    const target = button.dataset.target;

    tabButtons.forEach((btn) => {
      const isSelected = btn === button;
      btn.setAttribute("aria-selected", String(isSelected));
      btn.tabIndex = isSelected ? 0 : -1;
    });

    document.querySelectorAll<HTMLElement>("[data-tab-panel]").forEach((panel) => {
      panel.hidden = panel.dataset.tabPanel !== target;
    });

    button.focus();
  }

  tabButtons.forEach((button, index) => {
    button.addEventListener("click", () => activateTab(button));

    button.addEventListener("keydown", (event) => {
      let newIndex: number | null = null;

      if (event.key === "ArrowRight" || event.key === "ArrowDown") {
        newIndex = (index + 1) % tabButtons.length;
      } else if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
        newIndex = (index - 1 + tabButtons.length) % tabButtons.length;
      } else if (event.key === "Home") {
        newIndex = 0;
      } else if (event.key === "End") {
        newIndex = tabButtons.length - 1;
      }

      if (newIndex !== null) {
        event.preventDefault();
        activateTab(tabButtons[newIndex]);
      }
    });
  });
</script>
