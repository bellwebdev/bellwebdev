---
import Layout from "../../layouts/Layout.astro";
import BlogPost from "../../components/BlogPost.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, subtitle, blogImage } = entry.data;
// og:image must be a raster format: social platforms don't render SVG previews
const ogImage = blogImage.endsWith(".svg")
  ? "/projectImages/macbook-with-code.webp"
  : blogImage;
---

<Layout
  title={`${title} | Bell WebDev Blog`}
  description={subtitle}
  image={ogImage}
>
  <main>
    <BlogPost entry={entry} />
  </main>
</Layout>
