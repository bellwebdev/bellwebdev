---
import Layout from "../layouts/Layout.astro";
import HeroBanner from "../components/HeroBanner.astro";
import ContactForm from "../components/ContactForm.astro";
import styles from "./portfolio.module.scss";
---

<Layout
  title="Portfolio | Bell WebDev"
  description="Real projects in active development from Bell WebDev — not a static portfolio."
  image="/projectImages/Laptop-CSS-Code.webp"
>
  <main>
    <section class="darkBlueBg">
      <HeroBanner
        bgColor="darkBlueBg"
        btn={true}
        img="/projectImages/Laptop-CSS-Code.webp"
        imgAlt="Laptop displaying CSS code"
        heading="Currently Building"
        subheading="Real projects in active development — not a static portfolio."
      />
    </section>
    <section class="blueOpacityBg">
      <div class={`container ${styles.portfolio}`}>
        <h2 class={styles.sectionHeading}>
          Here's what I'm actively working on right now, alongside my
          full-time engineering work.
        </h2>
        <div class={styles.projectsRow}>
          <div class={styles.projectCol}>
            <div class={styles.projectCard}>
              <span class={styles.tag}>In Development</span>
              <h3>Community Networking App</h3>
              <p>
                A platform for connecting people with shared interests in
                their local area — built to help communities organize and
                stay in touch.
              </p>
            </div>
          </div>
          <div class={styles.projectCol}>
            <div class={styles.projectCard}>
              <span class={styles.tag}>
                Early Development — Pending Partnership
              </span>
              <h3>Solar Sales Field App</h3>
              <p>
                Working with a partner to build a tool for solar sales reps
                to manage door-to-door lead tracking and scheduling in the
                field.
              </p>
            </div>
          </div>
          <div class={styles.projectCol}>
            <div class={styles.projectCard}>
              <span class={styles.tag}>Background</span>
              <h3>5 Years of Professional Engineering</h3>
              <p>
                Before freelancing, I built and maintained production web
                software for a mid-size company for 5 years.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class={`container ${styles.finalSection}`}>
      <ContactForm
        formHeading="Have a project in mind?"
        formSubhead="Tell me a bit about your project and I'll get back to you within one business day."
      />
    </section>
  </main>
</Layout>
